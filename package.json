import { cn } from '../utils/cn';

interface ButtonProps {
  value: string;
  onClick: (value: string) => void;
  variant?: 'number' | 'operator' | 'function' | 'equals';
  className?: string;
}

export function Button({ value, onClick, variant = 'number', className }: ButtonProps) {
  const baseStyles = 'font-semibold text-xl rounded-2xl transition-all duration-150 active:scale-95 shadow-lg hover:shadow-xl flex items-center justify-center';
  
  const variantStyles = {
    number: 'bg-gray-700 hover:bg-gray-600 text-white',
    operator: 'bg-orange-500 hover:bg-orange-400 text-white',
    function: 'bg-gray-500 hover:bg-gray-400 text-white',
    equals: 'bg-green-500 hover:bg-green-400 text-white',
  };

  return (
    <button
      className={cn(baseStyles, variantStyles[variant], className)}
      onClick={() => onClick(value)}
    >
      {value}
    </button>
  );
}
